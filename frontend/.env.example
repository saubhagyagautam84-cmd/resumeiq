# Copy this file to .env.local for local overrides.
# In Vercel: add VITE_API_URL as an environment variable pointing to your Render backend.

# Leave blank to use the Vite dev proxy (http://localhost:8000 via /api)
VITE_API_URL=

# Example for production:
# VITE_API_URL=https://resumeiq-api.onrender.com
